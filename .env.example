# API keys - get from each provider's dashboard. Leave empty to skip that source.
# Financial Modeling Prep: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# SEC-API.io: https://sec-api.io/  (used for Form 4 insider sell data from SEC EDGAR)
SEC_API_KEY=

# Financial Datasets: https://financialdatasets.ai/
FINANCIAL_DATASETS_API_KEY=

# EODHD: https://eodhd.com/  (insider data requires All-In-One or Fundamentals plan)
EODHD_API_KEY=

# Set to true if on FMP free tier (250 calls/day) - limits API usage so some data loads
FMP_FREE_TIER=true

# Optional: when set, protects /api/scan and /api/dashboard/refresh (requires X-Admin-Key header or Authorization: Bearer <key>)
# ADMIN_API_KEY=

# Optional: absolute path to vibes-anomaly binary (must be under project root for security)
# VIBES_ANOMALY_BIN=

# Optional: path to vibes-anomaly.wasm for in-process Wasm execution via wazero
# Falls back to native binary, then pure Go. Run `make rust-wasm` to build.
# VIBES_ANOMALY_WASM=

# Cache backend: "file" (default, zero deps) or "sqlite" (survives ephemeral FS)
# VIBES_CACHE_BACKEND=file

# OpenTelemetry: set to "true" to enable distributed tracing (stdout exporter)
# Swap the exporter in internal/otel/otel.go for OTLP/gRPC in production.
# OTEL_ENABLED=false
